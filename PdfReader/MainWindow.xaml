<Window x:Class="PdfReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PDF Reader - Resize &amp; Crop" Height="700" Width="1000"
        MinHeight="400" MinWidth="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBarTray Grid.Row="0" Margin="4,2">
            <ToolBar>
                <Button x:Name="OpenButton" Content="Open PDF" Click="OpenButton_Click"/>
                <Separator/>
                <Button x:Name="PrevPageButton" Content="Previous" Click="PrevPageButton_Click"/>
                <Button x:Name="NextPageButton" Content="Next" Click="NextPageButton_Click"/>
                <TextBlock x:Name="PageLabel" Text="Page 0 of 0" VerticalAlignment="Center" Margin="12,0,0,0"/>
                <Separator/>
                <TextBlock Text="Output width (px):" VerticalAlignment="Center" Margin="8,0,2,0"/>
                <TextBox x:Name="WidthBox" Text="800" Width="60" VerticalAlignment="Center"/>
                <TextBlock Text="height (px):" VerticalAlignment="Center" Margin="4,0,2,0"/>
                <TextBox x:Name="HeightBox" Text="600" Width="60" VerticalAlignment="Center"/>
                <Separator/>
                <Button x:Name="ExportPageButton" Content="Export current page" Click="ExportPageButton_Click" ToolTip="Export current page at the specified width and height (pixels)"/>
                <Button x:Name="ExportAllButton" Content="Export all pages" Click="ExportAllButton_Click" ToolTip="Export every page at the specified dimensions"/>
            </ToolBar>
        </ToolBarTray>

        <!-- Crop / Resize options -->
        <Border Grid.Row="1" Background="#F0F0F0" Padding="8,6" BorderBrush="#CCC" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="CropCheckBox" Content="Crop to selection (page coords)" IsChecked="False" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Text="X:" VerticalAlignment="Center" Margin="0,0,2,0"/>
                <TextBox x:Name="CropXBox" Text="0" Width="50" VerticalAlignment="Center"/>
                <TextBlock Text="Y:" VerticalAlignment="Center" Margin="4,0,2,0"/>
                <TextBox x:Name="CropYBox" Text="0" Width="50" VerticalAlignment="Center"/>
                <TextBlock Text="W (0=full):" VerticalAlignment="Center" Margin="4,0,2,0"/>
                <TextBox x:Name="CropWBox" Text="0" Width="50" VerticalAlignment="Center"/>
                <TextBlock Text="H (0=full):" VerticalAlignment="Center" Margin="4,0,2,0"/>
                <TextBox x:Name="CropHBox" Text="0" Width="50" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- PDF page display -->
        <ScrollViewer Grid.Row="2" Margin="4" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Image x:Name="PageImage" Stretch="None" RenderOptions.BitmapScalingMode="HighQuality"/>
        </ScrollViewer>
    </Grid>
</Window>
